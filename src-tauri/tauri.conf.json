{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Freedive Gym",
  "version": "1.0.1",
  "identifier": "com.freedivegym.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Freedive Gym",
        "width": 480,
        "height": 800,
        "resizable": true,
        "fullscreen": false
